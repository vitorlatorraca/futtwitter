# ============================================
# FUTTWITTER - Environment Variables (.env)
# ============================================
# This file is an example. Copy it to .env locally and set real values.
# NEVER commit .env with secrets.

# --------------------------------------------
# REQUIRED (runtime)
# --------------------------------------------
# PostgreSQL connection string (Neon/Railway)
# Example:
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Secret used to sign session cookies (express-session + WebSocket session verification)
# REQUIRED in all environments.
SESSION_SECRET=

# --------------------------------------------
# Server
# --------------------------------------------
# Node environment: development | production
NODE_ENV=development

# Port where the server listens (Railway injects PORT automatically).
# Use PORT=5002 if you run backend on 5002 and client with Vite proxy.
PORT=5000

# --------------------------------------------
# CORS (optional)
# --------------------------------------------
# Only needed if your frontend runs on a DIFFERENT origin than the backend.
# Comma-separated list of allowed origins.
#
# Examples:
# CORS_ORIGIN=http://localhost:3000
# CORS_ORIGIN=https://your-app.up.railway.app,https://www.yourdomain.com
CORS_ORIGIN=

# --------------------------------------------
# Admin bootstrap (optional, but recommended)
# --------------------------------------------
# Comma-separated list of emails that should be treated as ADMIN (fallback).
# Used by backend RBAC checks when userType is not ADMIN.
#
# Example:
# ADMIN_EMAILS=admin@futtwitter.dev,other@company.com
ADMIN_EMAILS=

# --------------------------------------------
# DEV scripts (optional)
# --------------------------------------------
# Used by server/dev-promote-vitor-journalist.ts to pick the executor
# (executor must be included in ADMIN_EMAILS)
EXECUTOR_EMAIL=

# --------------------------------------------
# EMAIL (Resend — para "Esqueci minha senha" e notificações)
# --------------------------------------------
# Sem RESEND_API_KEY, o link de reset é impresso no console
# (útil para desenvolvimento local).
#
# 1) Crie uma conta em https://resend.com e gere uma API key.
# 2) Em produção, adicione e verifique o domínio (ex.: futtwitter.com)
#    no dashboard do Resend e configure SPF/DKIM no DNS.
# 3) EMAIL_FROM precisa usar um domínio verificado.
#    Para testes rápidos sem domínio: from=onboarding@resend.dev
#    (só envia pro email do dono da conta Resend).
RESEND_API_KEY=
EMAIL_FROM=FUTTWITTER <noreply@futtwitter.com>

# --------------------------------------------
# CLOUDINARY (image uploads)
# --------------------------------------------
# Create a free account at https://cloudinary.com
# Find these values in your Cloudinary Dashboard > Settings > API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --------------------------------------------
# RECOMMENDED FOR PRODUCTION
# --------------------------------------------
# Public URLs (useful for absolute links, redirects, etc.)
APP_URL=
CLIENT_URL=
SERVER_URL=

# Cookies (useful if you later need custom cookie domain / settings)
COOKIE_DOMAIN=
COOKIE_SECURE=
COOKIE_SAMESITE=

# Rate limiting (useful if you add rate limit middleware)
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=

# ============================================
# DEV USERS (reference only)
# ============================================
# These credentials are created by seed scripts in development.
# DO NOT use these in production.
#
# ADMIN_EMAIL=admin@futtwitter.dev
# ADMIN_PASSWORD=Admin@123
# JOURNALIST_EMAIL=maurinho@betting.dev
# JOURNALIST_PASSWORD=Senha@123

# --------------------------------------------
# --------------------------------------------
# Client (Vite)
# --------------------------------------------
# Base URL for the backend API consumed by the client bundle.
# In production (Vercel), leave empty — frontend and backend share the same
# origin (https://futtwitter.vercel.app), and /api/* is served by the same
# Vercel deployment via api/index.js.
# In dev, leave empty — Vite proxies /api to http://127.0.0.1:5000 (see vite.config.ts).
VITE_API_URL=

# --------------------------------------------
# Vite HMR (dev only)
# --------------------------------------------
# If you hit an HMR reconnect / reload loop when running Vite in Express middleware mode,
# you can disable HMR locally:
# DISABLE_HMR=1
DISABLE_HMR=
# Override the host used by the Vite HMR client (defaults to 127.0.0.1)
HMR_HOST=

# --------------------------------------------
# Replit (optional)
# --------------------------------------------
# Only used to enable Replit-only Vite plugins when running on Replit.
REPL_ID=

